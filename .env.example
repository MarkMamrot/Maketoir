# Marketoir Environment Variables

# --- GOOGLE SHEETS / AUTH ---
# 1. Base64 encode your entire credentials.json file and paste it here
# How to encode: cat credentials.json | base64
GOOGLE_APPLICATION_CREDENTIALS_BASE64=""
# OR alternatively provide absolute path if developing locally
# GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/your/credentials.json"

# --- NEXT AUTH (Phase 1) ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-strong-random-password"

# --- SHOPIFY OAUTH (Phase 1) ---
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SHOPIFY_SCOPES="read_products,read_inventory"

# --- META ADS OAUTH ---
META_APP_ID=""
META_APP_SECRET=""

# --- GOOGLE ADS OAUTH ---
GOOGLE_ADS_CLIENT_ID=""
GOOGLE_ADS_CLIENT_SECRET=""
GOOGLE_ADS_DEVELOPER_TOKEN=""
